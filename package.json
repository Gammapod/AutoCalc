{
  "name": "autocalc",
  "version": "0.1.0",
  "private": true,
  "description": "AutoCalc calculator progression app",
  "author": "AutoCalc",
  "type": "module",
  "main": "electron/main.cjs",
  "productName": "AutoCalc",
  "scripts": {
    "build": "npm run build:web",
    "build:web": "tsc -p tsconfig.json && node ./scripts/generate-unlock-graph-report.mjs",
    "build:desktop": "npm run build:web && node ./scripts/build-desktop.mjs",
    "build:watch": "tsc -w -p tsconfig.json",
    "ci:verify": "npm run build:web && node ./dist/tests/run-tests.js",
    "dev:serve": "node ./scripts/dev-server.mjs",
    "release:win:portable": "npm run ci:verify && node ./scripts/build-desktop.mjs",
    "test": "npm run ci:verify"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "electron": "^37.2.6",
    "electron-builder": "^26.0.12",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "algebrite": "^1.4.0",
    "chart.js": "^4.4.3",
    "katex": "^0.16.33"
  },
  "build": {
    "appId": "com.autocalc.app",
    "productName": "AutoCalc",
    "directories": {
      "output": "release"
    },
    "files": [
      "index.html",
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "asar": true,
    "artifactName": "AutoCalc-${version}-win-${arch}-portable.${ext}",
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
