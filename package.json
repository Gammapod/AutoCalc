{
  "name": "autocalc",
  "version": "0.9.19",
  "private": true,
  "description": "AutoCalc calculator progression app",
  "author": "AutoCalc",
  "type": "module",
  "main": "electron/main.cjs",
  "productName": "AutoCalc",
  "scripts": {
    "clean:dist": "node ./scripts/clean-dist.mjs",
    "build": "npm run build:web",
    "build:web": "npm run clean:dist && node ./scripts/generate-app-version.mjs && tsc -p tsconfig.app.json && node ./scripts/generate-unlock-graph-report.mjs",
    "build:web:incremental": "node ./scripts/generate-app-version.mjs && tsc -p tsconfig.app.json --incremental --tsBuildInfoFile .cache/tsbuildinfo.app && node ./scripts/generate-unlock-graph-report.mjs",
    "build:web:full": "npm run clean:dist && node ./scripts/generate-app-version.mjs && tsc -p tsconfig.json && node ./scripts/generate-unlock-graph-report.mjs",
    "build:web:full:incremental": "node ./scripts/generate-app-version.mjs && tsc -p tsconfig.json --incremental --tsBuildInfoFile .cache/tsbuildinfo.full && node ./scripts/generate-unlock-graph-report.mjs",
    "build:itch:zip": "node ./scripts/build-itch-zip.mjs",
    "build:release": "npm run build:web:full && npm run build:itch:zip",
    "build:mobile:webassets": "npm run build:web && node ./scripts/build-mobile-webassets.mjs",
    "mobile:android:sync": "npm run build:mobile:webassets && node ./scripts/mobile-android-sync.mjs",
    "build:android:apk": "npm run mobile:android:sync && node ./scripts/build-android-apk.mjs",
    "build:desktop": "npm run build:web && node ./scripts/build-desktop.mjs",
    "build:desktop:release": "npm run build:release && node ./scripts/build-desktop.mjs",
    "build:watch": "tsc -w -p tsconfig.app.json",
    "build:watch:full": "tsc -w -p tsconfig.json",
    "ci:verify": "npm run ci:health",
    "ci:verify:release": "node ./scripts/code-health-score.mjs --enforce=perfection",
    "ci:verify:release-notes": "node ./scripts/verify-release-notes.mjs",
    "ci:health": "node ./scripts/code-health-score.mjs --enforce=good-enough",
    "ci:verify:boundaries": "node ./scripts/check-boundaries.mjs",
    "ci:verify:parity": "npm run build:web:full && node ./dist/tests/run-tests.js --grep=\"^(v2/parity|v2/persistence-parity|contracts/parity-)\"",
    "ci:verify:action-event": "npm run build:web:full && node ./dist/tests/run-tests.js --grep=\"^contracts/action-event-round-trip$\"",
    "ci:verify:shell": "npm run build:web:full && node ./dist/tests/run-tests.js --grep=\"^(ui-shell/|ui-integration/(mobile-shell|desktop-shell)$)\"",
    "ci:verify:ui-complexity": "node ./scripts/check-ui-complexity.mjs",
    "dev:serve": "node ./scripts/dev-server.mjs",
    "release:win:portable": "npm run ci:verify:release && npm run build:release && node ./scripts/build-desktop.mjs",
    "test": "npm run ci:verify"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.2",
    "@types/node": "^25.3.0",
    "dependency-cruiser": "^17.3.9",
    "electron": "^37.2.6",
    "electron-builder": "^26.0.12",
    "happy-dom": "^20.8.3",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.2",
    "@capacitor/core": "^7.4.2",
    "algebrite": "^1.4.0",
    "chart.js": "^4.4.3",
    "katex": "^0.16.33"
  },
  "overrides": {
    "tar": "^7.5.11"
  },
  "build": {
    "appId": "com.autocalc.app",
    "productName": "AutoCalc",
    "directories": {
      "output": "release"
    },
    "files": [
      "index.html",
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "asar": true,
    "artifactName": "AutoCalc-${version}-win-${arch}-portable.${ext}",
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
