{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug AutoCalc (Chrome)",
      "type": "chrome",
      "request": "launch",
      "preLaunchTask": "debug: prepare",
      "url": "http://localhost:4173/index.html",
      "webRoot": "${workspaceFolder}",
      "sourceMaps": true,
      "outFiles": [
        "${workspaceFolder}/dist/**/*.js"
      ]
    },
    {
      "type": "node-terminal",
      "name": "JavaScript Debug Terminal",
      "request": "launch",
      "cwd": "${workspaceFolder}"
    }
  ]
}
