subgraph Math ["ℕ,ℤ"]
    %% Visualizer: cartesian plane (numberline when dealing with reals, then plane for complex numbers)
    
    MAT_inc[["[ n ++ ]"]] %% IMPLEMENTED
    %% Primitive
    %% Expanded form `[ 4 ++ ]` -> `[ 4 ℕ{..3 4◌⃕5..} ]`
    %% Completes ℕ on its own

    MAT_plus["a [ \+b ]"] %% IMPLEMENTED
    %% Expanded form `[ 4 + 3 ]` -> `[ 4 ++ ++ ++ ]`  
    MAT_mul["a [ × b ]"] %% IMPLEMENTED
    %% Expanded form `[ 4 × 3 ]` -> `[ 4 +4 +4 ]`
    %% CPX_impart ==> ROT_modulus
    %% CPX_repart ==> ROT_modulus
    %% ROT_rotate ==>|Iterate| CPX_horiz["n R±"]
    MAT_pow["a [ ^ b ]"] %% IMPLEMENTED
    %% Expanded form `[ 4 ^ 3 ]` -> `[ 4 ×4 ×4 ]`

    MAT_dec["[ n -- ]"] %% IMPLEMENTED
    %% Expanded form `[ 4 –– ]` -> `[ 4 ℤ{..3◌⃔4 5..} ]`
    %% Expanded form `[ 4 –– ]` -> `[ 4 ++⮌ ]`
    %% Completes ℤ with ++
    MAT_minus
    MAT_minus["a [ − b ]"] %% IMPLEMENTED
    %% Expanded form `[ 4 – 3 ]` -> `[ 4 –– –– –– ]`
    %% Expanded form `[ 4 – 3 ]` -> `[ 4 +⮌ 3 ]`

    %% DIV_mod ==> Lfloor["⌊n⌋"]
    %% %% Expanded form `[ ⌊(4÷3)⌋ ]` -> `[ (4÷3) – ((4÷3) ◇ 1) ]`
    %% Lfloor ==> Lceil["⌈n⌉"]
    %% %% Expanded form `[ ⌈(4÷3)⌉ ]` -> `[ (4÷3) + (1 – ((4÷3) ◇ 1)) ]`
    
    MAT_minus ==>|Iterate| DIV_cdiv
    MAT_mul ==>|Invert| DIV_cdiv
    DIV_cdiv ==>|Quotient| DIV_eudiv
    DIV_cdiv ===|Remainder| DIV_mod
    subgraph Division
        DIV_cdiv["a⨸b"] %% IMPLEMENTED
        %% Complex_Tuple – keyface `⫽ ╎ ◇→M`
        %% Expanded form `[ 4 ⨸ 3 ]` -> `[ (4 ⫽ 3) + ((4 ◇ 3) -M⭾R) ]`
        DIV_eudiv["a ⫽ b"] %% IMPLEMENTED
        %% Expanded form `[ 4 ⫽ 3 ]` -> `Σ[ ¬(4 – (3 × ℕ)) ]`
        DIV_mod["a◇b"] %% IMPLEMENTED
        %% Expanded form `[ 4 ◇ 3 ]` -> `[ 4 – (3 × (4 ⫽ 3)) ]`
    end
    
    MAT_pow ==>|Invert| LOG_clog
    DIV_cdiv ==>|Iterate| LOG_clog
    LOG_clog ==> LOG_eulog
    LOG_clog ==>|Remainder| LOG_resid
    subgraph Logs
        LOG_clog["a ⦷ b"] %% IMPLEMENTED
        %% Complex_Tuple – keyface `∥ ╎ 🞛→M`
        %% Expanded form `[ 4 ⦷ 3 ]` -> `[ (4 ∥ 3) + ((4 🞛 3) -M⭾R) ]`
        LOG_eulog["a [ ∥ b ]"] %% IMPLEMENTED
        %% Expanded form `[ 4 ∥ 3 ]` -> `Σ[ ¬(4 ◇ (3 ^ ℕ)) ]`
        LOG_resid["a [ 🞛 b ]"] %% IMPLEMENTED
        %% Expanded form `[ 4 🞛 3 ]` -> `[ 4 ÷ (3 ^ (4 ∥ 3)) ]`🞛
    end
end

