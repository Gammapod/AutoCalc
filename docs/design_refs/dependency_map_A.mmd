subgraph Complex_Math ["ℚ[𝕚]"]
    CPX_quarter[["[ z -M⭾R ]"]] %% IMPLEMENTED
    %% Expanded form `[ 4 -M⭾R ]` -> `[ 4 × √(-1) ]`
    %% Expanded form `[ 4 -M⭾R ]` -> `[ 4 ↶ 6 ]`
    %% Expanded form `[ 4 -M⭾R ]` -> `[ -3:00 ]`

    CPX_plusi["z [ M++ ]"] %% IMPLEMENTED
    %% Expanded form `[ z + i ]`
    CPX_minusi["z [ M–– ]"] %% IMPLEMENTED
    %% Expanded form `[ z – i ]`
    CPX_conj["z [ M± ]"] %% IMPLEMENTED
    %% Reflects only the imaginary part
    %% Expanded form `[ M± ]` -> [ M – (2 × M) + R]
    CPX_horiz["z [ R± ]"] %% IMPLEMENTED
    %% Reflects only the real part
    %% Expanded form `[ R± ]` -> [ R – (2 × R) + M]
    CPX_impart["z [ M→ ]"] %% IMPLEMENTED
    %% %% Ixpanded form `[ M→ ]` -> `[ (z + (z R±)) ÷ 2i ]`
    CPX_repart["z [ MC ]"] %% IMPLEMENTED
    %% %% Expanded form `[ MC ]` -> `[ (z + (z M±)) ÷ 2 ]`
    CPX_mid["a⦼b"]
    %% %% Expanded form `[ 4⦼3 ]` -> `[ (3 + (4 -M⭾R)) ÷ 2 ]
    CPX_norm["z [ 🞜 ]"]
    %% Expanded form `[ 4 🞜 ]` -> `[ R² + M² ]`
end

            
