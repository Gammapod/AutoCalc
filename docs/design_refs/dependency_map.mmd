%% Truth 4: Keep

%% Design guidelines:
%% 1. All operators can be constructed from atomic primitives
%% 2. Operators can be unary (takes previous operator result) or binary (takes previous operator result and second operand)
%% 3. User enters initial seed value, operators, and binary operands. A combination operator and second operand are a "operation slot"
%% 4. Values for seeds and binary operands can be digits 0-9
%% EXPERIMENTAL:
%% 5. The user can also enter Domains, which modifies the operation to make it an N-ary operation (examples: Σℕ or Πℙ), which repeat the operation across the domain.
%% Workflow example:
%% User enters "5 [ + 6 ]" (would resolve to 11), then presses the "Σℕ" key, which changes the input to "5 [ + Σℕ{1..6} ]" (would resolve to 26)
%% Second example: 
%% New unary operator Mfact["n!"]
%% Expanded form `5 [ ! ]` -> `[ Πℕ{1..5} ]` (would resolve to 120)

flowchart TD
    subgraph Step_Horizontal_Vertical_Ops ["nz"]
        Sinc["[ n ++ ]"]
        %% Primitive
        %% Expanded form `[ 4 ++ ]` -> `[ 4 ℕ{..3 4◌⃕5..} ]`
        %% Completes ℕ on its own

        Sdec["[ n -- ]"]
        %% Expanded form `[ 4 –– ]` -> `[ 4 ℤ{..3◌⃔4 5..} ]`
        %% Expanded form `[ 4 –– ]` -> `[ 4 ++⮌ ]`
        %% Completes ℤ with ++

        Sminus["a [ − b ]"]
        %% Expanded form `[ 4 - 3 ]` -> `[ 4 –– –– –– ]`
        %% Expanded form `[ 4 - 3 ]` -> `[ 4 +⮌ 3 ]`

        Splus["a [ \+b ]"]
        %% Expanded form `[ 4 + 3 ]` -> `[ 4 ++ ++ ++ ]`  

        %% Sfloor["⌊n⌋"]
        %% %% Expanded form `[ ⌊(4/3)⌋ ]` -> `[ (4/3) - ((4/3) ◇ 1) ]`
        %% Sceil["⌈n⌉"]
        %% %% %% Expanded form `[ ⌈(4/3)⌉ ]` -> `[ (4/3) + (1 - ((4/3) ◇ 1)) ]`

        %% Mc_tuple("Re(z) + Im(z)")
        %% %% Primitives
        %% Mc_tuple --> Mimag["[ Im(z) ]"]
        %% %% Expanded form `[ Im(z) ]` -> `[ n - a ↶ 12 ] ]`
        %% %% Returns the imaginary component (`b` from `a + b×i`) from part of n, 0 possible
        %% Mc_tuple --> Mreal["[ Re(z) ]"]
        %% %% Returns the non-imaginary component (`a` from `a + b×i`) from part of n, 0 possible


        subgraph Magnitude_Ops
            Mmul["a [ × b ]"]
            %% Expanded form `[ 4 × 3 ]` -> `[ 4 +4 +4 ]`

            Mneg["n [ ± ]"]
            %% Expanded form `[ 4 ± ]` -> `[ 4 × -1 ] ]`
            %% Expanded form `4 [ ± ]` -> `4 [ ↶ 12 ] ]`

            Mmodulus["z [ |z| ]"]
            %% Expanded form `[ |4| ]` -> `[ √(Re(4)² + Im(4)²) ]
            %% Expanded form `[ |4| ]` -> `[ ¬(4) × ±(4) ] + [ ¬¬(4) × (4)  ]`

            subgraph RaQios

                Qdiv["a [ ÷ b ]"]
                %% Expanded form `[ 4 ÷ 3 ]` -> `[ 4 × (⅓) ]`
                %% Expanded form `[ 4 ÷ 3 ]` -> `[ 4 ×⮌ 3 ]`    

                Qrecip["a [ ⨸ b]"]
                %% Expanded form `[ 4 ⨸ 3 ]` -> `[ 3 ÷ 4 ]` 

                Qdivtuple("⫽ + ◇")
                Qdivtuple --> Meudiv["a⫽b"]
                %% Expanded form `[ 4 ⫽ 3 ]` -> `Σ[ ¬(4 – (3 × ℕ)) ]`
                Qdivtuple --> Mmod["a◇b"]
                %% Expanded form `[ 4 ◇ 3 ]` -> `[ 3 – (4 × (4 ⫽ 3)) ]`
                Qper["％"]
                %% Expanded form `[ (a÷100) × b ]` <-- should 100 change based on base setting? 
            end 
            Mmul -->|Invert| Qdiv
            Qdiv --> Qdivtuple
            Qdiv --> Qper
            Qdiv -->|Invert| Qrecip
            
            subgraph Dimension_Ops    
                Epow["a [ ^ b ]"]
                %% Expanded form `[ 4 ^ 3 ]` -> `[ 4 ×4 ×4 ]`

                Eradical["[ ᵇ√a ]"]
                %% Expanded form `[ ³√(4) ]` -> `[ 4 ^ (1/3) ]`

                euradtuple("∥ × ⟐")
                euradtuple --> Eeurad["n [ ∥ p ]"]
                %% Expanded form `[ 4 ∥ 3 ]` -> `Σ[ ¬(4 ◇ (3 ^ ℕ)) ]`

                euradtuple --> Eresid["a [ ⟐ b ]"]
                %% Expanded form `[ 4 ⟐ 3 ]` -> `[ 4 ÷ (3 ^ (4 ∥ 3)) ]`

                subgraph Rotation_Ops ["× 𝕀"]
                    %% VITAL UX: make it abundantly clear that each rotation "unit" is 1/24 of a circle, or pi/12 radians. The math behind the scenes will be (n × e^(i*2pi*(n/24)))
                    Rtwentyfourth["[ n ⦨ ]"]
                    %% Primitive
                    %% Expanded form `[ 4 ⦨ ]` -> `[ 4 × e^(iπ/12)]`
                    Rrotate["a [ ↶ b ]"]
                    %% Expanded form `[ 4 ↶ 3 ]` -> `[ 4 × e^{i×2π×(3/24) ]`
                    %% Expanded form `[ 4 ↶ 3 ]` -> `[ 4 ⦨ ⦨ ⦨ ]`
                    Rquarter["[ n ⦜ ]"]
                    %% Primitive?
                    %% Expanded form `[ 4 ⦜ ]` -> `[ 4 ↶ 6 ]`
                    %% Expanded form `[ 4 ⦜ ]` -> `[ 4 × √(-1) ]`
                    Rc_tuple("|z| + θ")
                    Rc_tuple --> Rtheta["z [ θ ]"]
                    %% Expanded form `[ z θ ]` -> `[ ln(z{6+7i}/|{6+7i}|)/√(-1)]`
                    Rtrig("trig")
                end
                
                Rtwentyfourth -->|Iterate| Rrotate
                Rrotate --> Rquarter
                Eradical --> Rquarter["[ n ⦜ ]"]
                Rrotate --> Rc_tuple("|z| + θ")
                Rrotate --> Rtrig("trig")
            end
            Epow -->|Invert| Eradical["[ ᵇ√a ]"]
            Mmul -->|Iterate| Epow["a [ ^ b ]"]
            Eradical --> euradtuple

            subgraph Logic ["Logical Predicates"]
                Lnot["¬n"]
                %% Primitive
                %% Expanded form `[ 0 ≤ n ]
                Llte["a≤b"]
                %% Expanded form `[ ¬(a-b) ]
                Llt["a\< b"]
                %% Expanded form `[ (a≤b) × ¬(¬(a-b))]
                Leq["a≡b"]
                %% Expanded form `[ ¬((a<b) + (b<a)) ]
                Lmax["╧"]
                %% Expanded form `[ ((a<b)×b) + ¬((a≤b)×a) ]`
                Lmin["╤"]  
                %% Expanded form `[ ((a<b)×a) + ¬((a≤b)×b) ]`

            end
            Mmul --> Lnot
            Lnot --> Llte
            Llte --> Llt
            Llt --> Leq
            Llt --> Lmin
            Llt --> Lmax
            Sminus --> Llte

        end
        Mmul --> Mneg
        Splus -->|Iterate| Mmul["a [ × b ]"]
        %% Mimag --> Mmodulus
        %% Mreal --> Mmodulus
        %% Rrotate -->|Iterate| Mneg["n±"]
        Mneg --> Mmodulus
        Lnot --> Mmodulus
    end
    Sinc -->|Invert| Sdec["[ n -- ]"]
    Splus -->|Invert| Sminus["a [ − b ]"]
    Sdec -->|Iterate| Sminus["a [ − b ]"]
    Sinc -->|Iterate| Splus["a [ \+b ]"]
    %% Mmod --> Sfloor
    %% Sfloor --> Sceil

